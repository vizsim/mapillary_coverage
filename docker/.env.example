# Vorlage für docker/.env (gitignored). Werte eintragen und Datei kopieren:
#   cp docker/.env.example docker/.env

# --- NordVPN (gluetun) ---
NORD_USER=servercred_user
NORD_PASS=servercred_pw

# --- Backblaze B2: öffentliches Archiv für die Outputs ---
# Genutzt von scripts/upload_outputs_to_b2.sh, um die CSV (+ README/Metadata)
# nach b2://vizsim-public-archive/mapillary_coverage/ zu syncen. Öffentlich
# erreichbar unter https://data.vizsim.de/mapillary_coverage/.
#
#   Allow access to Bucket: vizsim-public-archive, Type: Read and Write.
#   (Derselbe App-Key wie in mapillary_trafficsigns/docker/.env ist ok.)
B2_ARCHIVE_KEY_ID=keyID_hier
B2_ARCHIVE_KEY=applicationKey_hier
